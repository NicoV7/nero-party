# Server
PORT=3000

# YouTube Data API v3 (required)
# Get your key at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Gemini API (primary AI provider)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# CORS origin (default: http://localhost:5173 for dev, set to * for tunneling/Docker)
# CORS_ORIGIN=*

# Ollama (optional fallback AI provider — runs locally)
# Install: https://ollama.ai
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ngrok (optional — for tunneling)
# NGROK_AUTHTOKEN=your_ngrok_token
